# Database
# When running in Docker Compose: use 'db' as hostname (docker-compose.yaml sets this)
# When running locally (npm run dev): use 'localhost' or your NAS hostname
DATABASE_URL=postgresql://gametracker:gametracker@localhost:5432/gametracker

# IGDB / Twitch API credentials
# Get these from: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_CLIENT_SECRET=your_twitch_client_secret_here

# HTTPS via Tailscale (see README → Enabling HTTPS)
# Your full Tailscale hostname — find it at https://login.tailscale.com/admin/machines
CADDY_HOSTNAME=your-machine-name.tailXXXXXX.ts.net

# Absolute path on the NAS host where the .crt and .key files are stored
CERTS_DIR=/root/gametracker/certs
