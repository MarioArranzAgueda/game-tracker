# Replace the hostname with your actual Tailscale machine name.
# Find it at https://login.tailscale.com/admin/machines
# Format: <machine-name>.<tailnet-name>.ts.net
#
# Example: gametracker-nas.tail1234ab.ts.net

# HTTPS only for Tailscale hostname
{$CADDY_HOSTNAME} {
  tls /certs/{$CADDY_HOSTNAME}.crt /certs/{$CADDY_HOSTNAME}.key
  reverse_proxy app:3000
}

# HTTP for local network access (no TLS needed on LAN)
:80 {
  reverse_proxy app:3000
}